<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">Create Account</h1>
    <form action="/auth/register" method="POST" class="form">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required minlength="3" placeholder="At least 3 characters" />
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required minlength="6" placeholder="At least 6 characters" />
      </div>
      <div class="form-group">
        <label for="role">Role</label>
        <select id="role" name="role">
          <option value="user">User (read-only)</option>
          <option value="admin">Admin (full access)</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Create Account</button>
    </form>
    <p class="auth-link">Already have an account? <a href="/auth/login">Login</a></p>
  </div>
</div>

<%- include('../partials/footer') %>
