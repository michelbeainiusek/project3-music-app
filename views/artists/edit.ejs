<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page-header">
  <h1>Edit Artist</h1>
  <a href="/artists/<%= artist._id %>" class="btn btn-outline">Cancel</a>
</div>

<div class="form-card">
  <form action="/artists/<%= artist._id %>?_method=PUT" method="POST" class="form">
    <div class="form-group">
      <label for="name">Name <span class="required">*</span></label>
      <input type="text" id="name" name="name" required value="<%= artist.name %>" />
    </div>
    <div class="form-group">
      <label for="country">Country</label>
      <input type="text" id="country" name="country" value="<%= artist.country %>" />
    </div>
    <div class="form-group">
      <label for="bio">Bio</label>
      <textarea id="bio" name="bio" rows="4"><%= artist.bio %></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/artists/<%= artist._id %>" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
