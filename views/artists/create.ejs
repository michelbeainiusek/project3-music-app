<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page-header">
  <h1>Add Artist</h1>
  <a href="/artists" class="btn btn-outline">Cancel</a>
</div>

<div class="form-card">
  <form action="/artists" method="POST" class="form">
    <div class="form-group">
      <label for="name">Name <span class="required">*</span></label>
      <input type="text" id="name" name="name" required placeholder="Artist name" />
    </div>
    <div class="form-group">
      <label for="country">Country</label>
      <input type="text" id="country" name="country" placeholder="e.g. USA" />
    </div>
    <div class="form-group">
      <label for="bio">Bio</label>
      <textarea id="bio" name="bio" rows="4" placeholder="Short biography..."></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Create Artist</button>
      <a href="/artists" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
