<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page-header">
  <h1>Artists</h1>
  <% if (currentUser.role === 'admin') { %>
    <a href="/artists/new" class="btn btn-primary">+ Add Artist</a>
  <% } %>
</div>

<% if (artists.length === 0) { %>
  <div class="empty-state">No artists yet.<% if (currentUser.role === 'admin') { %> <a href="/artists/new">Add the first one.</a><% } %></div>
<% } else { %>
  <div class="table-wrapper">
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Country</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% artists.forEach(artist => { %>
        <tr>
          <td><a href="/artists/<%= artist._id %>"><%= artist.name %></a></td>
          <td><%= artist.country %></td>
          <td class="actions">
            <a href="/artists/<%= artist._id %>" class="btn btn-sm btn-outline">View</a>
            <% if (currentUser.role === 'admin') { %>
              <a href="/artists/<%= artist._id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
              <form action="/artists/<%= artist._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this artist and all their songs?')">
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
