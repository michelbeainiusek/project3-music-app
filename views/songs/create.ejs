<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page-header">
  <h1>Add Song</h1>
  <a href="/songs" class="btn btn-outline">Cancel</a>
</div>

<div class="form-card">
  <form action="/songs" method="POST" class="form">
    <div class="form-group">
      <label for="title">Title <span class="required">*</span></label>
      <input type="text" id="title" name="title" required placeholder="Song title" />
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="duration">Duration (seconds) <span class="required">*</span></label>
        <input type="number" id="duration" name="duration" required min="1" placeholder="e.g. 213" />
      </div>
      <div class="form-group">
        <label for="releaseYear">Release Year <span class="required">*</span></label>
        <input type="number" id="releaseYear" name="releaseYear" required min="1900" max="<%= new Date().getFullYear() + 1 %>" placeholder="e.g. 2023" />
      </div>
    </div>
    <div class="form-group">
      <label for="artist">Artist <span class="required">*</span></label>
      <select id="artist" name="artist" required>
        <option value="">-- Select Artist --</option>
        <% artists.forEach(a => { %>
          <option value="<%= a._id %>"><%= a.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="playlists">Add to Playlists <span class="hint">(hold Ctrl/Cmd for multiple)</span></label>
      <select id="playlists" name="playlists" multiple size="5">
        <% playlists.forEach(pl => { %>
          <option value="<%= pl._id %>"><%= pl.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Create Song</button>
      <a href="/songs" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
