<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page-header">
  <h1>Edit Song</h1>
  <a href="/songs/<%= song._id %>" class="btn btn-outline">Cancel</a>
</div>

<div class="form-card">
  <form action="/songs/<%= song._id %>?_method=PUT" method="POST" class="form">
    <div class="form-group">
      <label for="title">Title <span class="required">*</span></label>
      <input type="text" id="title" name="title" required value="<%= song.title %>" />
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="duration">Duration (seconds) <span class="required">*</span></label>
        <input type="number" id="duration" name="duration" required min="1" value="<%= song.duration %>" />
      </div>
      <div class="form-group">
        <label for="releaseYear">Release Year <span class="required">*</span></label>
        <input type="number" id="releaseYear" name="releaseYear" required min="1900" max="<%= new Date().getFullYear() + 1 %>" value="<%= song.releaseYear %>" />
      </div>
    </div>
    <div class="form-group">
      <label for="artist">Artist <span class="required">*</span></label>
      <select id="artist" name="artist" required>
        <% artists.forEach(a => { %>
          <option value="<%= a._id %>" <%= a._id.toString() === song.artist.toString() ? 'selected' : '' %>><%= a.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="playlists">Playlists <span class="hint">(hold Ctrl/Cmd for multiple)</span></label>
      <select id="playlists" name="playlists" multiple size="5">
        <% playlists.forEach(pl => { %>
          <option value="<%= pl._id %>" <%= song.playlists.map(id => id.toString()).includes(pl._id.toString()) ? 'selected' : '' %>><%= pl.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/songs/<%= song._id %>" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
