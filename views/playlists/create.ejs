<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page-header">
  <h1>Create Playlist</h1>
  <a href="/playlists" class="btn btn-outline">Cancel</a>
</div>

<div class="form-card">
  <form action="/playlists" method="POST" class="form">
    <div class="form-group">
      <label for="name">Name <span class="required">*</span></label>
      <input type="text" id="name" name="name" required placeholder="Playlist name" />
    </div>
    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="3" placeholder="Optional description..."></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Create Playlist</button>
      <a href="/playlists" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
