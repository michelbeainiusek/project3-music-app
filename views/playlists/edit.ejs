<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page-header">
  <h1>Edit Playlist</h1>
  <a href="/playlists/<%= playlist._id %>" class="btn btn-outline">Cancel</a>
</div>

<div class="form-card">
  <form action="/playlists/<%= playlist._id %>?_method=PUT" method="POST" class="form">
    <div class="form-group">
      <label for="name">Name <span class="required">*</span></label>
      <input type="text" id="name" name="name" required value="<%= playlist.name %>" />
    </div>
    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="3"><%= playlist.description %></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/playlists/<%= playlist._id %>" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
