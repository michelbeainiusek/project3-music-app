<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page-header">
  <h1>Playlists</h1>
  <% if (currentUser.role === 'admin') { %>
    <a href="/playlists/new" class="btn btn-primary">+ Create Playlist</a>
  <% } %>
</div>

<% if (playlists.length === 0) { %>
  <div class="empty-state">No playlists yet.<% if (currentUser.role === 'admin') { %> <a href="/playlists/new">Create the first one.</a><% } %></div>
<% } else { %>
  <div class="table-wrapper">
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Songs</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% playlists.forEach(pl => { %>
        <tr>
          <td><a href="/playlists/<%= pl._id %>"><%= pl.name %></a></td>
          <td><%= pl.description || '—' %></td>
          <td><%= pl.songs.length %></td>
          <td class="actions">
            <a href="/playlists/<%= pl._id %>" class="btn btn-sm btn-outline">View</a>
            <% if (currentUser.role === 'admin') { %>
              <a href="/playlists/<%= pl._id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
              <form action="/playlists/<%= pl._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this playlist?')">
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
