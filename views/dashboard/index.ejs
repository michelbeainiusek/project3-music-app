<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page-header">
  <h1>Dashboard</h1>
  <p class="text-muted">Welcome back, <strong><%= currentUser.username %></strong></p>
</div>

<div class="stats-grid">
  <a href="/artists" class="stat-card">
    <div class="stat-icon">&#127908;</div>
    <div class="stat-value"><%= artistCount %></div>
    <div class="stat-label">Artists</div>
  </a>
  <a href="/songs" class="stat-card">
    <div class="stat-icon">&#127925;</div>
    <div class="stat-value"><%= songCount %></div>
    <div class="stat-label">Songs</div>
  </a>
  <a href="/playlists" class="stat-card">
    <div class="stat-icon">&#127911;</div>
    <div class="stat-value"><%= playlistCount %></div>
    <div class="stat-label">Playlists</div>
  </a>
</div>

<% if (currentUser.role === 'admin') { %>
<div class="section">
  <h2>Quick Actions</h2>
  <div class="quick-actions">
    <a href="/artists/new" class="btn btn-primary">+ Add Artist</a>
    <a href="/songs/new" class="btn btn-primary">+ Add Song</a>
    <a href="/playlists/new" class="btn btn-primary">+ Create Playlist</a>
  </div>
</div>
<% } %>

<div class="section">
  <h2>Browse</h2>
  <div class="quick-actions">
    <a href="/artists" class="btn btn-outline">View Artists</a>
    <a href="/songs" class="btn btn-outline">View Songs</a>
    <a href="/playlists" class="btn btn-outline">View Playlists</a>
  </div>
</div>

<%- include('../partials/footer') %>
